package-as: Resonance

move-folders:
  Resonance/Resonance_Data: Resonance_Data

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .github
  - tools
  - docs
  - build.py
  - "*.zip"
  - __pycache__
  - .gitignore
  - .luacheckrc
  - stylua.toml
  - Makefile
  - README.md
  - LISTING.md
  - LICENSE
  - assets
